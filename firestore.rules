rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Feedback Collections (v1, v2, v3)
    match /feedbacks/{feedbackId} {
      allow create: if isValidFeedback(request.resource.data);
      allow read, list: if true;
    }
    match /feedbacks_v2/{feedbackId} {
      allow create: if isValidFeedback(request.resource.data);
      allow read, list: if true;
    }
    match /feedbacks_v3/{feedbackId} {
      allow create: if isValidFeedback(request.resource.data);
      allow read, list: if true;
      allow delete: if false; 
    }

    // HELPERS
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isValidFeedback(data) {
      let requiredFields = ['rating', 'feedback', 'createdAt', 'userName'];
      return data.keys().hasAll(requiredFields) 
        && data.keys().size() >= 4
        && data.rating is int 
        && data.rating >= 1 
        && data.rating <= 5
        && data.feedback is string 
        && data.feedback.size() >= 1
        && data.feedback.size() <= 1000
        && data.userName is string
        && data.userName.size() >= 1
        && data.userName.size() <= 100
        && data.createdAt == request.time
        && (data.keys().size() == 4 || (data.keys().hasAll(['articleId']) && data.articleId is string && data.articleId.size() <= 128));
    }
  }
}
